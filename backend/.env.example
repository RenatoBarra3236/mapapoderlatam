PORT=3001
DATABASE_URL=postgresql+psycopg://mapapoder:mapapoder@localhost:5432/mapapoderlatam
# Rust CLI accepts RUST_DATABASE_URL first. Use postgresql:// for native Rust postgres.
RUST_DATABASE_URL=postgresql://mapapoder:mapapoder@localhost:5432/mapapoderlatam
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for real Mercado Publico/ChileCompra API calls. Never commit a real ticket.
CHILECOMPRA_TICKET=
CHILECOMPRA_BASE_URL=https://api.mercadopublico.cl
CHILECOMPRA_SEED_TENDER_CODES=
CHILECOMPRA_SEED_OC_CODES=
CHILECOMPRA_DAILY_BUDGET=9000
CHILECOMPRA_NIGHT_START=22:00
CHILECOMPRA_NIGHT_END=07:00
CHILECOMPRA_CACHE_DIR=.cache/chilecompra
CHILECOMPRA_MAX_REQUESTS=20
CHILECOMPRA_DELAY_MS=1000
CHILECOMPRA_RETRY=2
CHILECOMPRA_BACKOFF_MS=2000
INFOLOBBY_ENDPOINT=
INFOPROBIDAD_ENDPOINT=
SERVEL_DATA_URL=
REGISTRO_COLABORADORES_URL=

# AI — elige proveedor con AI_PROVIDER y pon la key del proveedor elegido.
# Claude: obtén key en console.anthropic.com
# Gemini: obtén key en ai.google.dev (AI Studio, no Google Cloud Console)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
